generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BORROWER
  LENDER
  ADMIN
}

enum LoanStatus {
  PENDING
  ACTIVE
  FUNDED
  CLOSED
  DEFAULTED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum RepaymentStatus {
  PENDING
  PAID
  OVERDUE
  DEFAULTED
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         UserRole
  creditScore  Int?          @map("credit_score")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  loans        LoanRequest[]
  investments  Investment[]
  reviews      LoanRequest[] @relation("LoanReviewer")
  notifications Notification[]

  @@map("users")
}

model LoanRequest {
  id               String      @id @default(cuid())
  borrowerId       String      @map("borrower_id")
  amount           Decimal     @db.Decimal(12, 2)
  interestRate     Decimal     @map("interest_rate") @db.Decimal(5, 2)
  riskGrade        String      @map("risk_grade")
  status           LoanStatus  @default(PENDING)
  purpose          String?
  termMonths       Int         @default(12) @map("term_months")
  annualIncome     Decimal     @db.Decimal(12, 2) @map("annual_income")
  existingDebt     Decimal     @db.Decimal(12, 2) @map("existing_debt")
  employmentStatus String      @map("employment_status")
  emiAmount        Decimal     @db.Decimal(12, 2) @map("emi_amount")
  probabilityOfDefault Decimal? @db.Decimal(5, 2) @map("probability_of_default")
  riskBand         String?     @map("risk_band")
  decisionReason   String?     @map("decision_reason")
  recommendedRate  Decimal?    @db.Decimal(5, 2) @map("recommended_rate")
  reviewStatus     ReviewStatus @default(PENDING) @map("review_status")
  reviewedBy       String?     @map("reviewed_by")
  reviewedAt       DateTime?   @map("reviewed_at")
  reviewNotes      String?     @map("review_notes")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  borrower         User        @relation(fields: [borrowerId], references: [id])
  reviewer         User?       @relation("LoanReviewer", fields: [reviewedBy], references: [id])
  investments      Investment[]
  repayments       Repayment[]

  @@map("loan_requests")
}

model Investment {
  id             String      @id @default(cuid())
  lenderId       String      @map("lender_id")
  loanId         String      @map("loan_id")
  amountInvested Decimal     @db.Decimal(12, 2) @map("amount_invested")
  createdAt      DateTime    @default(now()) @map("created_at")
  lender         User        @relation(fields: [lenderId], references: [id])
  loan           LoanRequest @relation(fields: [loanId], references: [id])

  @@map("investments")
}

model Repayment {
  id         String          @id @default(cuid())
  loanId     String          @map("loan_id")
  amountPaid Decimal         @db.Decimal(12, 2) @map("amount_paid")
  dueDate    DateTime        @map("due_date")
  paidAt     DateTime?       @map("paid_at")
  status     RepaymentStatus @default(PENDING)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  loan       LoanRequest     @relation(fields: [loanId], references: [id])

  @@map("repayments")
}

model Notification {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  channel   NotificationChannel
  type      String
  subject   String?
  message   String
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?          @map("sent_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  user      User               @relation(fields: [userId], references: [id])

  @@map("notifications")
}
