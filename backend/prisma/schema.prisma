generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BORROWER
  LENDER
  ADMIN
}

enum LoanStatus {
  PENDING
  ACTIVE
  FUNDED
  CLOSED
  DEFAULTED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum RepaymentStatus {
  PENDING
  PAID
  OVERDUE
  DEFAULTED
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum WalletType {
  PLATFORM
  BORROWER
  LENDER
}

enum LedgerAccountType {
  CASH
  FUNDING_HOLD
  LOAN_RECEIVABLE
  INTEREST_REVENUE
  FEE_REVENUE
  BORROWER_PAYABLE
  LENDER_PAYABLE
  RESERVE
}

enum LedgerEntryDirection {
  DEBIT
  CREDIT
}

enum TransferStatus {
  PENDING
  POSTED
  FAILED
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

enum PaymentPurpose {
  LENDER_TOP_UP
  BORROWER_REPAYMENT
  BORROWER_DISBURSAL
  LENDER_PAYOUT
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  CANCELLED
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         UserRole
  creditScore  Int?          @map("credit_score")
  kycStatus    String        @default("PENDING") @map("kyc_status")
  kycDocUrl    String?       @map("kyc_doc_url")
  autoRepay    Boolean       @default(true) @map("auto_repay")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  loans        LoanRequest[]
  investments  Investment[]
  reviews      LoanRequest[] @relation("LoanReviewer")
  notifications Notification[]
  wallets       Wallet[]
  payments      Payment[]
  preferences   LenderPreference?

  @@map("users")
}

model LenderPreference {
  id            String   @id @default(cuid())
  lenderId      String   @unique @map("lender_id")
  riskGrades    String[] @map("risk_grades") // e.g. ["A", "B"]
  minReturn     Decimal  @db.Decimal(5, 2) @map("min_return")
  maxDuration   Int      @map("max_duration")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lender        User     @relation(fields: [lenderId], references: [id])

  @@map("lender_preferences")
}


model LoanRequest {
  id               String      @id @default(cuid())
  borrowerId       String      @map("borrower_id")
  amount           Decimal     @db.Decimal(12, 2)
  interestRate     Decimal     @map("interest_rate") @db.Decimal(5, 2)
  riskGrade        String      @map("risk_grade")
  status           LoanStatus  @default(PENDING)
  purpose          String?
  termMonths       Int         @default(12) @map("term_months")
  annualIncome     Decimal     @db.Decimal(12, 2) @map("annual_income")
  existingDebt     Decimal     @db.Decimal(12, 2) @map("existing_debt")
  employmentStatus String      @map("employment_status")
  emiAmount        Decimal     @db.Decimal(12, 2) @map("emi_amount")
  probabilityOfDefault Decimal? @db.Decimal(5, 2) @map("probability_of_default")
  riskBand         String?     @map("risk_band")
  decisionReason   String?     @map("decision_reason")
  recommendedRate  Decimal?    @db.Decimal(5, 2) @map("recommended_rate")
  reviewStatus     ReviewStatus @default(PENDING) @map("review_status")
  reviewedBy       String?     @map("reviewed_by")
  reviewedAt       DateTime?   @map("reviewed_at")
  reviewNotes      String?     @map("review_notes")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  borrower         User        @relation(fields: [borrowerId], references: [id])
  reviewer         User?       @relation("LoanReviewer", fields: [reviewedBy], references: [id])
  investments      Investment[]
  repayments       Repayment[]
  payments         Payment[]

  @@map("loan_requests")
}

model Investment {
  id             String      @id @default(cuid())
  lenderId       String      @map("lender_id")
  loanId         String      @map("loan_id")
  amountInvested Decimal     @db.Decimal(12, 2) @map("amount_invested")
  createdAt      DateTime    @default(now()) @map("created_at")
  lender         User        @relation(fields: [lenderId], references: [id])
  loan           LoanRequest @relation(fields: [loanId], references: [id])

  @@map("investments")
}

model Repayment {
  id         String          @id @default(cuid())
  loanId     String          @map("loan_id")
  amountPaid Decimal         @db.Decimal(12, 2) @map("amount_paid")
  dueDate    DateTime        @map("due_date")
  paidAt     DateTime?       @map("paid_at")
  status     RepaymentStatus @default(PENDING)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  loan       LoanRequest     @relation(fields: [loanId], references: [id])

  @@map("repayments")
}

model Notification {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  channel   NotificationChannel
  type      String
  subject   String?
  message   String
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?          @map("sent_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  user      User               @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Wallet {
  id        String            @id @default(cuid())
  userId    String?           @map("user_id")
  type      WalletType
  currency  String            @default("USD")
  balance   Decimal           @db.Decimal(14, 2) @default(0)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  user      User?             @relation(fields: [userId], references: [id])
  accounts  LedgerAccount[]

  @@unique([userId, type])
  @@map("wallets")
}

model LedgerAccount {
  id        String            @id @default(cuid())
  walletId   String           @map("wallet_id")
  type      LedgerAccountType
  balance   Decimal           @db.Decimal(14, 2) @default(0)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  wallet    Wallet            @relation(fields: [walletId], references: [id])
  entries   LedgerEntry[]

  @@unique([walletId, type])
  @@map("ledger_accounts")
}

model Transfer {
  id             String         @id @default(cuid())
  loanId         String?        @map("loan_id")
  investmentId   String?        @map("investment_id")
  repaymentId    String?        @map("repayment_id")
  referenceType  String         @map("reference_type")
  description    String
  amount         Decimal        @db.Decimal(14, 2)
  currency       String         @default("USD")
  status         TransferStatus @default(POSTED)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  entries        LedgerEntry[]
  payment        Payment?

  @@map("transfers")
}

model LedgerEntry {
  id              String               @id @default(cuid())
  transferId      String               @map("transfer_id")
  ledgerAccountId String               @map("ledger_account_id")
  amount          Decimal              @db.Decimal(14, 2)
  direction       LedgerEntryDirection
  memo            String?
  createdAt       DateTime             @default(now()) @map("created_at")
  transfer        Transfer             @relation(fields: [transferId], references: [id])
  ledgerAccount   LedgerAccount        @relation(fields: [ledgerAccountId], references: [id])

  @@map("ledger_entries")
}

model Payment {
  id                String          @id @default(cuid())
  userId            String          @map("user_id")
  loanId            String?         @map("loan_id")
  transferId        String?         @unique @map("transfer_id")
  provider          PaymentProvider
  purpose           PaymentPurpose
  status            PaymentStatus   @default(PENDING)
  currency          String          @default("USD")
  amount            Decimal         @db.Decimal(14, 2)
  providerPaymentId String?         @map("provider_payment_id")
  providerOrderId   String?         @map("provider_order_id")
  clientSecret      String?         @map("client_secret")
  metadata          Json?
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  user              User            @relation(fields: [userId], references: [id])
  loan              LoanRequest?    @relation(fields: [loanId], references: [id])
  transfer          Transfer?       @relation(fields: [transferId], references: [id])

  @@map("payments")
}

model WebhookEvent {
  id          String          @id @default(cuid())
  provider    PaymentProvider
  eventType   String          @map("event_type")
  providerId  String?         @map("provider_id")
  payload     Json
  processedAt DateTime?       @map("processed_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@map("webhook_events")
}
